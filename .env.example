# ── Qdrant ────────────────────────────────────────────────────────────
# URL for the Qdrant vector store (Docker on the same machine by default)
QDRANT_URL=http://localhost:6333

# ── MCP Server ────────────────────────────────────────────────────────
# Host/port the FastMCP SSE server listens on
MCP_HOST=127.0.0.1
MCP_PORT=8000

# ── Embedding model ────────────────────────────────────────────────────
# HuggingFace model name used for both ingestion and query-time encoding
EMBED_MODEL=all-MiniLM-L6-v2

# ── LLM (for the agent) ────────────────────────────────────────────────
# Set to the base URL of your LLM API (Ollama, OpenAI-compatible, etc.)
# Example for local Ollama: http://localhost:11434/v1
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.2
# If using a paid API that requires a key:
# LLM_API_KEY=sk-...

# ── Frontend ───────────────────────────────────────────────────────────
# The public URL the Next.js frontend uses to talk to the agent API
NEXT_PUBLIC_API_URL=http://localhost:3000
