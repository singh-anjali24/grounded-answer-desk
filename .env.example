# ── Qdrant ────────────────────────────────────────────────────────────
# URL for the Qdrant vector store (Docker on the same machine by default)
QDRANT_URL=http://localhost:6333

# ── MCP Server ────────────────────────────────────────────────────────
# Host/port the FastMCP Streamable HTTP server listens on
MCP_HOST=0.0.0.0
MCP_PORT=8001

# ── OpenClaw Gateway ──────────────────────────────────────────────────
# URL of the OpenClaw Gateway running on the VPS (set on Vercel too)
OPENCLAW_URL=http://localhost:18789
# Gateway auth token (from ~/.openclaw/openclaw.json → gateway.auth.token)
OPENCLAW_TOKEN=your-openclaw-token-here
# Port OpenClaw gateway listens on
OPENCLAW_PORT=18789

# ── Google AI Studio (LLM) ────────────────────────────────────────────
# Get your free API key at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-google-ai-studio-key-here

# ── MCP URL (for Vercel — must be public) ─────────────────────────────
# Set this to: http://<VPS_PUBLIC_IP>:8001/sse
MCP_URL=http://localhost:8001/sse

# ── Embedding model ────────────────────────────────────────────────────
# HuggingFace model name used for both ingestion and query-time encoding
EMBED_MODEL=all-MiniLM-L6-v2

# ── Frontend ───────────────────────────────────────────────────────────
# The public URL the Next.js frontend uses to talk to the agent API
NEXT_PUBLIC_API_URL=http://localhost:3000
